# Flask
FLASK_SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development

# Admin dashboard credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# Team signup password (given to invited attendees)
EVENT_PASSWORD=juneteenth2025

# Database
# For local development, leave DATABASE_URL unset to use SQLite (data/beer_olympics.db).
# On Render, set DATABASE_URL to your Postgres Internal Database URL.
# Render provides URLs starting with postgres:// — the app normalises these automatically.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
